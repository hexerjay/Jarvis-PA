{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the personal assistant.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "telegramChatId": { "type": "number", "description": "Linked Telegram Chat ID" },
        "whatsappToken": { "type": "string", "description": "WhatsApp API Token" },
        "slackToken": { "type": "string", "description": "Slack Bot Token" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between the user and the assistant.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "assistant"] },
        "source": { "type": "string", "enum": ["web", "telegram"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "hasAttachment": { "type": "boolean" },
        "attachmentName": { "type": "string" }
      },
      "required": ["text", "sender", "source", "timestamp", "userId"]
    },
    "Task": {
      "title": "Task",
      "description": "A task managed by the assistant.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["title", "status", "createdAt", "userId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled event or meeting.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["title", "startTime", "endTime", "createdAt", "userId"]
    },
    "DesktopCommand": {
      "title": "DesktopCommand",
      "description": "A command queued for the local desktop script to execute.",
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "action": { "type": "string", "enum": ["open_file", "search_file", "open_bookmark", "add_bookmark", "run_script", "bookmark", "move_file"] },
        "status": { "type": "string", "enum": ["pending", "executed", "failed"] },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["command", "action", "status", "createdAt", "userId"]
    },
    "UserSkills": {
      "title": "UserSkills",
      "description": "Skills enabled by the user for the assistant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "webSearch": { "type": "boolean" },
        "marketResearch": { "type": "boolean" },
        "dataAnalysis": { "type": "boolean" },
        "gmailIntegration": { "type": "boolean" },
        "calendarManagement": { "type": "boolean" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles."
    },
    "/user_skills/{userId}": {
      "schema": { "$ref": "UserSkills" },
      "description": "User enabled skills."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Chat history."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "Task" },
      "description": "User tasks."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "Appointment" },
      "description": "User appointments and schedule."
    },
    "/desktop_commands/{commandId}": {
      "schema": { "$ref": "DesktopCommand" },
      "description": "Queue of commands for the local desktop."
    }
  }
}
